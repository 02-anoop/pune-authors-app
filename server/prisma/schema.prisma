generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("AUTHOR")
  createdAt DateTime @default(now())
  address   String?
  interests String?
  phone     String?
  queries   Query[]
}

model Author {
  id                 Int                 @id @default(autoincrement())
  name               String
  email              String              @unique
  phone              String
  bio                String
  photoUrl           String?
  status             String              @default("Pending")
  rejectionReason    String?
  transactionId      String?
  paymentScreenshot  String?
  createdAt          DateTime            @default(now())
  whatsapp           String?
  extraData          Json?
  qrCodeUrl          String?
  books              Book[]
  eventRegistrations EventRegistration[]
  formResponses      FormResponse[]
  eventAuthors       EventAuthor[]
  eventBooks         EventBook[]
  queries            Query[]
}

model Query {
  id          Int      @id @default(autoincrement())
  authorId    Int?
  userId      Int?
  subject     String
  message     String
  status      String   @default("Pending") // Pending, Answered
  reply       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  author      Author?   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Book {
  id              Int         @id @default(autoincrement())
  title           String
  genre           String
  subGenre        String?
  synopsis        String
  pages           Int?
  mrp             Float
  coverUrl        String?
  status          String      @default("Pending")
  rejectionReason String?
  authorId        Int
  createdAt       DateTime    @default(now())
  overpriced      Boolean     @default(false)
  stock           Int         @default(0)
  airportStock    Int         @default(0)
  fairStock       Int         @default(0)
  author          Author      @relation(fields: [authorId], references: [id])
  orderItems      OrderItem[]
  reviews         BookReview[]
  eventBooks      EventBook[]
}

model Order {
  id                Int         @id @default(autoincrement())
  customerName      String
  customerEmail     String?
  customerPhone     String?
  address           String?
  amount            Float
  paymentScreenshot String?
  transactionId     String?
  createdAt         DateTime    @default(now())
  status            String      @default("Pending Verification")
  items             OrderItem[]
}

model OrderItem {
  id             Int      @id @default(autoincrement())
  orderId        Int
  bookId         Int
  quantity       Int      @default(1)
  status         String   @default("Pending Verification")
  createdAt      DateTime @default(now())
  trackingNumber  String?
  rejectionReason String?
  book            Book     @relation(fields: [bookId], references: [id])
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ContactInquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model GalleryEvent {
  id          Int      @id @default(autoincrement())
  location    String
  place       String
  city        String
  date        DateTime
  duration    String
  authors     Int
  booksSold   Int
  type        String
  description String
  photoUrl    String
  createdAt   DateTime @default(now())
  images      GalleryImage[]
}

model GalleryImage {
  id              Int      @id @default(autoincrement())
  galleryEventId  Int
  url             String
  caption         String?
  dateTaken       DateTime?
  createdAt       DateTime @default(now())
  
  galleryEvent    GalleryEvent @relation(fields: [galleryEventId], references: [id], onDelete: Cascade)
}

model Activity {
  id            Int                 @id @default(autoincrement())
  name          String
  date          String
  city          String
  charges       Float
  type          String
  status        String              @default("OPEN")
  createdAt     DateTime            @default(now())
  registrations EventRegistration[]
}

model EventRegistration {
  id                Int      @id @default(autoincrement())
  createdAt         DateTime @default(now())
  activityId        Int
  amount            Float
  authorId          Int
  booksIds          String
  paymentScreenshot String?
  status            String   @default("Pending Verification")
  activity          Activity @relation(fields: [activityId], references: [id])
  author            Author   @relation(fields: [authorId], references: [id])
}

model FormTemplate {
  id          Int            @id @default(autoincrement())
  title       String
  description String?
  fields      Json
  createdAt   DateTime       @default(now())
  type        String         @default("Literary Events")
  responses   FormResponse[]
}

model FormResponse {
  id             Int          @id @default(autoincrement())
  formTemplateId Int
  authorId       Int
  answers        Json
  createdAt      DateTime     @default(now())
  author         Author       @relation(fields: [authorId], references: [id])
  formTemplate   FormTemplate @relation(fields: [formTemplateId], references: [id])
}

model BookReview {
  id           Int      @id @default(autoincrement())
  bookId       Int
  reviewerName String
  rating       Int      // 1-5
  comment      String
  createdAt    DateTime @default(now())
  book         Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model Event {
  id                Int           @id @default(autoincrement())
  name              String
  location          String
  date              String
  duration          String
  description       String?
  brochureUrl       String?
  status            String        @default("Upcoming") // Upcoming, Ongoing, Past
  commissionPercent Float?
  commissionFlat    Float?
  createdAt         DateTime      @default(now())
  broadcastStatus   String        @default("None")     // None, AuthorsOnly, CustomersAlso
  
  eventAuthors    EventAuthor[]
  eventBooks      EventBook[]
}

model EventAuthor {
  id              Int       @id @default(autoincrement())
  eventId         Int
  authorId        Int
  optInStatus     String    @default("Pending") // Pending, Opted-In, Opted-Out
  createdAt       DateTime  @default(now())
  
  event           Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  author          Author    @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model EventBook {
  id              Int       @id @default(autoincrement())
  eventId         Int
  bookId          Int
  authorId        Int
  listedStock     Int       @default(0) // Stock committed for this event
  soldStock       Int       @default(0) // Stock sold during the event
  returnedStock   Int       @default(0) // Listed - Sold
  createdAt       DateTime  @default(now())
  
  event           Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  book            Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author          Author    @relation(fields: [authorId], references: [id], onDelete: Cascade)
}
