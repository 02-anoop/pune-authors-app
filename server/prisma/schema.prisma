generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("AUTHOR")
  createdAt DateTime @default(now())
  address   String?
  interests String?
  phone     String?
  queries   Query[]
}

model AuthorDraft {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  step           Int      @default(0)
  form           Json
  books          Json
  qualifications Json
  extraDataState Json
  skillInput     String?
  hobbyInput     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  completed      Boolean  @default(false)
}

model OtpVerification {
  email     String   @id
  otp       String
  expiresAt DateTime
}

model Author {
  id                 Int                 @id @default(autoincrement())
  name               String
  email              String              @unique
  phone              String
  bio                String
  photoUrl           String?
  status             String              @default("Pending")
  createdAt          DateTime            @default(now())
  whatsapp           String?
  rejectionReason    String?
  paymentScreenshot  String?
  transactionId      String?
  extraData          Json?
  qrCodeUrl          String?
  city               String?
  facebook           String?
  instagram          String?
  penName            String?
  state              String?
  aadharNumber       String?
  address            String?
  qualification      String?
  age                String?
  experience         String?
  hobbies            String?
  skills             String?
  whyJoining         String?
  certificateUrl     String?
  district           String?
  dob                String?
  hobbiesJson        Json?
  institution        String?
  pincode            String?
  qualificationsJson Json?
  skillsJson         Json?
  subject            String?
  books              Book[]
  eventAuthors       EventAuthor[]
  eventBooks         EventBook[]
  eventRegistrations EventRegistration[]
  formResponses      FormResponse[]
  posOrders          PosOrder[]
  queries            Query[]
}

model Query {
  id        Int      @id @default(autoincrement())
  authorId  Int?
  subject   String
  message   String
  status    String   @default("Pending")
  reply     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int?
  author    Author?  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Book {
  id              Int            @id @default(autoincrement())
  title           String
  genre           String
  subGenre        String?
  synopsis        String
  pages           Int?
  mrp             Float
  coverUrl        String?
  status          String         @default("Pending")
  authorId        Int
  createdAt       DateTime       @default(now())
  overpriced      Boolean        @default(false)
  stock           Int            @default(0)
  airportStock    Int            @default(0)
  fairStock       Int            @default(0)
  rejectionReason String?
  edition         String?
  format          String?
  isbn            String?
  language        String?
  publicationDate String?
  publisher       String?
  subtitle        String?
  backCoverUrl    String?
  printFormat     String?
  purpose         String?
  author          Author         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reviews         BookReview[]
  eventBooks      EventBook[]
  orderItems      OrderItem[]
  posOrderItems   PosOrderItem[]
}

model Order {
  id                Int         @id @default(autoincrement())
  customerName      String
  customerEmail     String?
  customerPhone     String?
  address           String?
  amount            Float
  paymentScreenshot String?
  createdAt         DateTime    @default(now())
  status            String      @default("Pending Verification")
  transactionId     String?
  items             OrderItem[]
}

model OrderItem {
  id                Int       @id @default(autoincrement())
  orderId           Int
  bookId            Int
  quantity          Int       @default(1)
  status            String    @default("Pending Verification")
  createdAt         DateTime  @default(now())
  trackingNumber    String?
  rejectionReason   String?
  deliveredAt       DateTime?
  dispatchedAt      DateTime?
  acceptedAt        DateTime?
  feedbackComments  String?
  feedbackCondition String?
  feedbackRating    Int?
  book              Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ContactInquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model GalleryEvent {
  id          Int            @id @default(autoincrement())
  location    String
  place       String
  city        String
  date        DateTime
  duration    String
  authors     Int
  booksSold   Int
  type        String
  description String
  photoUrl    String
  createdAt   DateTime       @default(now())
  eventId     Int?           @unique
  event       Event?         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  images      GalleryImage[]
}

model GalleryImage {
  id             Int          @id @default(autoincrement())
  galleryEventId Int
  url            String
  caption        String?
  dateTaken      DateTime?
  createdAt      DateTime     @default(now())
  status         String       @default("Pending")
  galleryEvent   GalleryEvent @relation(fields: [galleryEventId], references: [id], onDelete: Cascade)
}

model Activity {
  id            Int                 @id @default(autoincrement())
  name          String
  date          String
  city          String
  charges       Float
  type          String
  status        String              @default("OPEN")
  createdAt     DateTime            @default(now())
  registrations EventRegistration[]
}

model EventRegistration {
  id                Int      @id @default(autoincrement())
  createdAt         DateTime @default(now())
  activityId        Int
  amount            Float
  authorId          Int
  booksIds          String
  paymentScreenshot String?
  status            String   @default("Pending Verification")
  activity          Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  author            Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model FormTemplate {
  id          Int            @id @default(autoincrement())
  title       String
  description String?
  fields      Json
  createdAt   DateTime       @default(now())
  type        String         @default("Literary Events")
  responses   FormResponse[]
}

model FormResponse {
  id             Int          @id @default(autoincrement())
  formTemplateId Int
  authorId       Int
  answers        Json
  createdAt      DateTime     @default(now())
  author         Author       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  formTemplate   FormTemplate @relation(fields: [formTemplateId], references: [id], onDelete: Cascade)
}

model BookReview {
  id           Int      @id @default(autoincrement())
  bookId       Int
  reviewerName String
  rating       Int
  comment      String
  createdAt    DateTime @default(now())
  book         Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model Event {
  id                Int           @id @default(autoincrement())
  name              String
  location          String
  date              String
  duration          String
  status            String        @default("Upcoming")
  createdAt         DateTime      @default(now())
  broadcastStatus   String        @default("None")
  brochureUrl       String?
  description       String?
  commissionFlat    Float?
  commissionPercent Float?
  eventType         String        @default("Book Fair")
  feeType           String        @default("Per Author")
  registrationFee   Float         @default(0)
  bannerUrl         String?
  livePosEnabled    Boolean       @default(true)
  endTime           String?
  startTime         String?
  eventAuthors      EventAuthor[]
  eventBooks        EventBook[]
  galleryEvent      GalleryEvent?
  posOrders         PosOrder[]
}

model EventAuthor {
  id                Int      @id @default(autoincrement())
  eventId           Int
  authorId          Int
  optInStatus       String   @default("Pending")
  createdAt         DateTime @default(now())
  paymentScreenshot String?
  author            Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  event             Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventBook {
  id            Int      @id @default(autoincrement())
  eventId       Int
  bookId        Int
  authorId      Int
  listedStock   Int      @default(0)
  soldStock     Int      @default(0)
  returnedStock Int      @default(0)
  createdAt     DateTime @default(now())
  author        Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  book          Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model PosOrder {
  id               Int            @id @default(autoincrement())
  authorId         Int
  eventId          Int
  totalAmount      Float
  paymentMethod    String         @default("UPI")
  createdAt        DateTime       @default(now())
  paymentReference String?
  paymentStatus    String         @default("CONFIRMED")
  saleSource       String         @default("BOOK_FAIR")
  author           Author         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  event            Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items            PosOrderItem[]
}

model PosOrderItem {
  id         Int      @id @default(autoincrement())
  posOrderId Int
  bookId     Int
  quantity   Int
  price      Float
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  posOrder   PosOrder @relation(fields: [posOrderId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  message   String
  target    String   @default("ALL")
  createdAt DateTime @default(now())
}
