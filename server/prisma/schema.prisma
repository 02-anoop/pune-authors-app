generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?
  address   String?
  interests String?
  password  String
  role      String   @default("AUTHOR") // AUTHOR, ADMIN, CUSTOMER
  createdAt DateTime @default(now())
}


model Author {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String
  bio       String
  photoUrl  String?
  whatsapp  String?
  status    String   @default("Pending") // Pending, Approved
  books     Book[]
  eventRegistrations EventRegistration[]
  formResponses      FormResponse[]
  createdAt DateTime @default(now())
}

model Book {
  id        Int      @id @default(autoincrement())
  title     String
  genre     String
  subGenre  String?
  synopsis  String
  pages     Int?
  mrp       Float
  coverUrl  String?
  stock     Int      @default(0)
  airportStock Int   @default(0)
  fairStock Int      @default(0)
  overpriced Boolean @default(false)
  status    String   @default("Pending") // Pending, Approved
  authorId  Int
  author    Author   @relation(fields: [authorId], references: [id])
  orderItems OrderItem[]
  createdAt DateTime @default(now())
}

model Order {
  id                Int         @id @default(autoincrement())
  customerName      String
  customerEmail     String?
  customerPhone     String?
  address           String?
  amount            Float
  paymentScreenshot String?
  status            String      @default("Pending Verification")
  items             OrderItem[]
  createdAt         DateTime    @default(now())
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  bookId    Int
  book      Book     @relation(fields: [bookId], references: [id])
  quantity  Int      @default(1)
  status    String   @default("Pending Verification") // Pending Verification, Approved, Dispatched, Completed
  trackingNumber String?
  createdAt DateTime @default(now())
}

model ContactInquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model GalleryEvent {
  id          Int      @id @default(autoincrement())
  location    String
  place       String
  city        String
  date        DateTime
  duration    String
  authors     Int
  booksSold   Int
  type        String
  description String
  photoUrl    String
  createdAt   DateTime @default(now())
}

model Activity {
  id        Int      @id @default(autoincrement())
  name      String
  date      String
  city      String
  charges   Float
  type      String   // 'Literary Events', 'Book Fairs', 'Flybraries', 'Cafe'
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  registrations EventRegistration[]
}

model EventRegistration {
  id                Int      @id @default(autoincrement())
  authorId          Int
  author            Author   @relation(fields: [authorId], references: [id])
  activityId        Int
  activity          Activity @relation(fields: [activityId], references: [id])
  booksIds          String   // JSON string of book IDs registered for this event
  paymentScreenshot String?
  amount            Float
  status            String   @default("Pending Verification") // Pending Verification, Approved
  createdAt         DateTime @default(now())
}

model FormTemplate {
  id          Int      @id @default(autoincrement())
  title       String
  type        String   @default("Literary Events")
  description String?
  fields      Json     // Array of field definitions
  createdAt   DateTime @default(now())
  responses   FormResponse[]
}

model FormResponse {
  id             Int          @id @default(autoincrement())
  formTemplateId Int
  authorId       Int
  answers        Json         // Key-value pairs of responses
  createdAt      DateTime     @default(now())
  
  formTemplate   FormTemplate @relation(fields: [formTemplateId], references: [id])
  author         Author       @relation(fields: [authorId], references: [id])
}
