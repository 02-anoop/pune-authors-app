generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("AUTHOR")
  createdAt DateTime @default(now())
  address   String?
  interests String?
  phone     String?
  queries   Query[]
}

model Author {
  id                 Int                 @id @default(autoincrement())
  name               String
  email              String              @unique
  phone              String
  bio                String
  photoUrl           String?
  status             String              @default("Pending")
  rejectionReason    String?
  transactionId      String?
  paymentScreenshot  String?
  createdAt          DateTime            @default(now())
  whatsapp           String?
  penName            String?
  city               String?
  state              String?
  instagram          String?
  facebook           String?
  extraData          Json?
  qrCodeUrl          String?
  qualification      String?
  age                String?
  experience         String?
  skills             String?
  hobbies            String?
  whyJoining         String?
  aadharNumber       String?
  address            String?
  books              Book[]
  eventRegistrations EventRegistration[]
  formResponses      FormResponse[]
  eventAuthors       EventAuthor[]
  eventBooks         EventBook[]
  queries            Query[]
  posOrders          PosOrder[]
}

model Query {
  id          Int      @id @default(autoincrement())
  authorId    Int?
  userId      Int?
  subject     String
  message     String
  status      String   @default("Pending") // Pending, Answered
  reply       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  author      Author?   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Book {
  id              Int         @id @default(autoincrement())
  title           String
  genre           String
  subGenre        String?
  synopsis        String
  pages           Int?
  mrp             Float
  coverUrl        String?
  status          String      @default("Pending")
  rejectionReason String?
  authorId        Int
  createdAt       DateTime    @default(now())
  overpriced      Boolean     @default(false)
  stock           Int         @default(0)
  airportStock    Int         @default(0)
  fairStock       Int         @default(0)
  
  subtitle        String?
  language        String?
  isbn            String?
  publisher       String?
  publicationDate String?
  edition         String?
  format          String?
  author          Author      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  reviews         BookReview[]
  eventBooks      EventBook[]
  posOrderItems   PosOrderItem[]
}

model Order {
  id                Int         @id @default(autoincrement())
  customerName      String
  customerEmail     String?
  customerPhone     String?
  address           String?
  amount            Float
  paymentScreenshot String?
  transactionId     String?
  createdAt         DateTime    @default(now())
  status            String      @default("Pending Verification")
  items             OrderItem[]
}

model OrderItem {
  id             Int      @id @default(autoincrement())
  orderId        Int
  bookId         Int
  quantity       Int      @default(1)
  status         String   @default("Pending Verification")
  createdAt      DateTime @default(now())
  dispatchedAt   DateTime?
  deliveredAt    DateTime?
  trackingNumber  String?
  rejectionReason String?
  book            Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ContactInquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model GalleryEvent {
  id          Int      @id @default(autoincrement())
  location    String
  place       String
  city        String
  date        DateTime
  duration    String
  authors     Int
  booksSold   Int
  type        String
  description String
  photoUrl    String
  eventId     Int?     @unique
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  images      GalleryImage[]
}

model GalleryImage {
  id              Int      @id @default(autoincrement())
  galleryEventId  Int
  url             String
  caption         String?
  dateTaken       DateTime?
  createdAt       DateTime @default(now())
  
  galleryEvent    GalleryEvent @relation(fields: [galleryEventId], references: [id], onDelete: Cascade)
}

model Activity {
  id            Int                 @id @default(autoincrement())
  name          String
  date          String
  city          String
  charges       Float
  type          String
  status        String              @default("OPEN")
  createdAt     DateTime            @default(now())
  registrations EventRegistration[]
}

model EventRegistration {
  id                Int      @id @default(autoincrement())
  createdAt         DateTime @default(now())
  activityId        Int
  amount            Float
  authorId          Int
  booksIds          String
  paymentScreenshot String?
  status            String   @default("Pending Verification")
  activity          Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  author            Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model FormTemplate {
  id          Int            @id @default(autoincrement())
  title       String
  description String?
  fields      Json
  createdAt   DateTime       @default(now())
  type        String         @default("Literary Events")
  responses   FormResponse[]
}

model FormResponse {
  id             Int          @id @default(autoincrement())
  formTemplateId Int
  authorId       Int
  answers        Json
  createdAt      DateTime     @default(now())
  author         Author       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  formTemplate   FormTemplate @relation(fields: [formTemplateId], references: [id], onDelete: Cascade)
}

model BookReview {
  id           Int      @id @default(autoincrement())
  bookId       Int
  reviewerName String
  rating       Int      // 1-5
  comment      String
  createdAt    DateTime @default(now())
  book         Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model Event {
  id                Int           @id @default(autoincrement())
  name              String
  location          String
  date              String
  duration          String
  description       String?
  brochureUrl       String?
  bannerUrl         String?
  status            String        @default("Upcoming") // Upcoming, Ongoing, Past
  commissionPercent Float?
  commissionFlat    Float?
  createdAt         DateTime      @default(now())
  broadcastStatus   String        @default("None")     // None, AuthorsOnly, CustomersAlso
  
  eventType         String        @default("Book Fair") // Book Fair, Literature Festival, Book Launch, Workshop, Online Event, Other
  registrationFee   Float         @default(0)
  feeType           String        @default("Per Author") // Per Author, Per Title
  
  eventAuthors    EventAuthor[]
  eventBooks      EventBook[]
  posOrders       PosOrder[]
  galleryEvent    GalleryEvent?
}

model EventAuthor {
  id              Int       @id @default(autoincrement())
  eventId         Int
  authorId        Int
  optInStatus     String    @default("Pending") // Pending, Opted-In, Opted-Out
  paymentScreenshot String?
  createdAt       DateTime  @default(now())
  
  event           Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  author          Author    @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model EventBook {
  id              Int       @id @default(autoincrement())
  eventId         Int
  bookId          Int
  authorId        Int
  listedStock     Int       @default(0) // Stock committed for this event
  soldStock       Int       @default(0) // Stock sold during the event
  returnedStock   Int       @default(0) // Listed - Sold
  createdAt       DateTime  @default(now())
  
  event           Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  book            Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author          Author    @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model PosOrder {
  id               Int            @id @default(autoincrement())
  authorId         Int
  eventId          Int
  totalAmount      Float
  paymentMethod    String         @default("UPI") // UPI, Cash
  paymentStatus    String         @default("CONFIRMED")
  paymentReference String?
  saleSource       String         @default("BOOK_FAIR")
  createdAt        DateTime       @default(now())
  
  author           Author         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  event            Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items            PosOrderItem[]
}

model PosOrderItem {
  id          Int       @id @default(autoincrement())
  posOrderId  Int
  bookId      Int
  quantity    Int
  price       Float
  
  posOrder    PosOrder  @relation(fields: [posOrderId], references: [id], onDelete: Cascade)
  book        Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
}
